{
  "name": "@byspec/numbers",
  "version": "0.1.0",
  "description": "Spec-anchored numeric test cases — IEEE 754 and ECMAScript",
  "type": "module",
  "exports": {
    ".": "./src/index.js",
    "./ieee754": "./src/ieee754/index.js",
    "./ecmascript": "./src/ecmascript/index.js"
  },
  "typesVersions": {
    "*": {
