        "./src/index.d.ts"
      ],
      "ieee754": [
        "./src/ieee754/index.d.ts"
      ],
      "ecmascript": [
        "./src/ecmascript/index.d.ts"
      ]
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "devDependencies": {
    "jasmine": "^5.0.0"
  },
  "scripts": {
    "test": "jasmine 'spec/**/*.spec.js'"
